@model WebBanSanPhamCongNghe.Areas.Admin.Data.Customer

@{
    ViewData["Title"] = "Details";
}

<!--begin::App Content Header-->
<div class="app-content-header">
    <!--begin::Container-->
    <div class="container-fluid">
        <!--begin::Row-->
        <div class="row">
            <div class="col-sm-6"><h3 class="mb-0">Customer</h3></div>
        </div>
        <!--end::Row-->
    </div>
    <!--end::Container-->
</div>
<!--end::App Content Header-->
<!--begin::App Content-->
<div class="app-content">
    <!--begin::Container-->
    <div class="container-fluid">
        <!--begin::Row-->
        <div class="row">
            <div class="col-12">
                <!--begin::Card-->
                <div class="card card-primary card-outline">
                    <!--begin::Header-->
                    <div class="card-header">
                        <div class="card-title">
                            <h3>Details</h3>
                        </div>
                    </div>
                    <!--end::Header-->
                    <!--begin::Body-->
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-2">
                                @Html.DisplayNameFor(model => model.FirstName)
                            </dt>
                            <dd class="col-sm-10">
                                @Html.DisplayFor(model => model.FirstName)
                            </dd>
                            <dt class="col-sm-2">
                                @Html.DisplayNameFor(model => model.LastName)
                            </dt>
                            <dd class="col-sm-10">
                                @Html.DisplayFor(model => model.LastName)
                            </dd>
                            <dt class="col-sm-2">
                                @Html.DisplayNameFor(model => model.Address)
                            </dt>
                            <dd class="col-sm-10">
                                @Html.DisplayFor(model => model.Address)
                            </dd>
                            <dt class="col-sm-2">
                                @Html.DisplayNameFor(model => model.Phone)
                            </dt>
                            <dd class="col-sm-10">
                                @Html.DisplayFor(model => model.Phone)
                            </dd>
                            <dt class="col-sm-2">
                                @Html.DisplayNameFor(model => model.Email)
                            </dt>
                            <dd class="col-sm-10">
                                @Html.DisplayFor(model => model.Email)
                            </dd>
                            <dt class="col-sm-2">
                                @Html.DisplayNameFor(model => model.Img)
                            </dt>
                            <dd class="col-sm-10">
                                <img src="~/Images/Customer/@Model.Img" class="img-fluid rounded-circle"
                                     alt="Image"
                                     width="100" height="200"
                                     style="object-fit: cover;">
                            </dd>
                            <dt class="col-sm-2">
                                @Html.DisplayNameFor(model => model.RegisteredAt)
                            </dt>
                            <dd class="col-sm-10">
                                @Html.DisplayFor(model => model.RegisteredAt)
                            </dd>
                            <dt class="col-sm-2">
                                @Html.DisplayNameFor(model => model.UpdateAt)
                            </dt>
                            <dd class="col-sm-10">
                                @Html.DisplayFor(model => model.UpdateAt)
                            </dd>
                            <dt class="col-sm-2">
                                @Html.DisplayNameFor(model => model.DateOfBirth)
                            </dt>
                            <dd class="col-sm-10">
                                @Html.DisplayFor(model => model.DateOfBirth)
                            </dd>
                            <dt class="col-sm-2">
                                @Html.DisplayNameFor(model => model.IsActive)
                            </dt>
                            <dd class="col-sm-10">
                                @((bool)Model.IsActive ? "Active" : "Inactive")
                            </dd>
                            <dt class="col-sm-2">
                                @Html.DisplayNameFor(model => model.Role)
                            </dt>
                            <dd class="col-sm-10">
                                @(Model.Role == 0 ? "User" : Model.Role == 1 ? "Admin" : "")
                            </dd>
                        </dl>
                    </div>
                    <!--end::Body-->
                    <!--begin::Footer-->
                    <div class="card-footer">
                        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Edit</a>
                        <a asp-action="Index" class="btn btn-primary float-end">Back to List</a>
                    </div>
                    <!--end::Footer-->
                </div>
                <!--end::Card-->
            </div>
        </div>
        <!--end::Row-->
    </div>
    <!--end::Container-->
</div>
<!--end::App Content-->

