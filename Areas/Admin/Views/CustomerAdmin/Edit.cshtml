@model WebBanSanPhamCongNghe.Areas.Admin.Data.Customer

@{
    ViewData["Title"] = "Edit";
}

<!--begin::App Content Header-->
<div class="app-content-header">
    <!--begin::Container-->
    <div class="container-fluid">
        <!--begin::Row-->
        <div class="row">
            <div class="col-sm-6"><h3 class="mb-0">Customer</h3></div>
        </div>
        <!--end::Row-->
    </div>
    <!--end::Container-->
</div>
<!--end::App Content Header-->
<!--begin::App Content-->
<div class="app-content">
    <!--begin::Container-->
    <div class="container-fluid">
        <!--begin::Row-->
        <div class="row">
            <div class="col-12">
                <!--begin::Card-->
                <div class="card card-warning card-outline">
                    <!--begin::Header-->
                    <div class="card-header">
                        <div class="card-title">
                            <h3>Edit</h3>
                        </div>
                    </div>
                    <!--end::Header-->
                    <!--begin::Form-->
                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />
                        <!--begin::Body-->
                        <div class="card-body">
                            <div class="mb-3">
                                <div class="form-group">
                                    <label asp-for="FirstName" class="control-label"></label>
                                    <input asp-for="FirstName" class="form-control" />
                                    <span asp-validation-for="FirstName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="form-group">
                                    <label asp-for="LastName" class="control-label"></label>
                                    <input asp-for="LastName" class="form-control" />
                                    <span asp-validation-for="LastName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="form-group">
                                    <label asp-for="Address" class="control-label"></label>
                                    <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                                    <span asp-validation-for="Address" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="form-group">
                                    <label asp-for="Phone" class="control-label"></label>
                                    <input asp-for="Phone" class="form-control" />
                                    <span asp-validation-for="Phone" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="form-group">
                                    <label asp-for="Email" class="control-label"></label>
                                    <input asp-for="Email" class="form-control" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="form-group">
                                    <label asp-for="Img" class="control-label"></label><br />
                                    <input type="hidden" asp-for="Img" />
                                    <img src="~/Images/Customer/@Model.Img" class="img-fluid rounded-circle my-2"
                                         alt="Image"
                                         width="100" height="200"
                                         style="object-fit: cover;">
                                    <input class="form-control"
                                           type="file" accept="image/gif, image/jpeg, image/png"
                                           name="ImageUpload" />
                                    <span asp-validation-for="Img" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="form-group">
                                    <label asp-for="DateOfBirth" class="control-label"></label>
                                    <input asp-for="DateOfBirth" type="date" class="form-control" />
                                    <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="form-group">
                                    <label asp-for="IsActive" class="control-label"></label>
                                    <div>
                                        <div class="form-check">
                                            <label class="form-check-label" for="Active">Active</label>
                                            <input id="Active" name="IsActive" type="radio" class="form-check-input" value="true" @((bool)Model.IsActive ? "checked" : "") />
                                        </div>
                                        <div class="form-check">
                                            <label class="form-check-label" for="Inactive">Inactive</label>
                                            <input id="Inactive" name="IsActive" type="radio" class="form-check-input" value="false" @((bool)Model.IsActive ? "" : "checked") />
                                        </div>
                                    </div>
                                    <span asp-validation-for="IsActive" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="form-group">
                                    <label asp-for="Role" class="control-label"></label>
                                    <select asp-for="Role" class="form-control">
                                        <option value="0">User</option>
                                        <option value="1">Admin</option>
                                    </select>
                                    <span asp-validation-for="Role" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        <!--end::Body-->
                        <!--begin::Footer-->
                        <div class="card-footer">
                            <div class="form-group">
                                <input type="submit" value="Save" class="btn btn-warning" />
                                <a class="btn btn-primary float-end" asp-action="Index">Back to List</a>
                            </div>
                        </div>
                        <!--end::Footer-->
                    </form>
                    <!--end::Form-->
                </div>
                <!--end::Card-->
            </div>
        </div>
        <!--end::Row-->
    </div>
    <!--end::Container-->
</div>
<!--end::App Content-->

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

