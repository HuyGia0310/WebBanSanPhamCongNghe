    <!--begin::Container-->
    <div class="container-fluid">
        <!--begin::Row-->
        <div class="row">
            <!--begin::Col-->
            <div class="col-lg-3 col-6">
                <!--begin::Small Box Widget 1-->
                <div class="small-box text-bg-primary">
                    <div class="inner">
                        <h3>@Model.TotalPaymentsThisMonth</h3>
                        <p>Payments/Month</p>
                    </div>
                    <svg class="small-box-icon"
