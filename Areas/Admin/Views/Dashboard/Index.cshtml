@model WebBanSanPhamCongNghe.Areas.Admin.Models.Dashboard

@{
    ViewData["Title"] = "Dashboard";
}

<!--begin::App Content Header-->
<div class="app-content-header">
    <!--begin::Container-->
    <div class="container-fluid">
        <!--begin::Row-->
        <div class="row">
            <div class="col-sm-6"><h3 class="mb-0">Dashboard</h3></div>
             <div class="col-sm-6 text-end">
                <form method="get" asp-action="Index">
                    <label for="SelectedYear">Chọn năm:</label>
                    <select asp-for="SelectedYear" asp-items="Model.AvailableYears" class="form-select d-inline w-auto" onchange="this.form.submit()"></select>
                </form>
            </div>
        </div>
        <!--end::Row-->
    </div>
    <!--end::Container-->
</div>
<!--end::App Content Header-->
<!--begin::App Content-->
