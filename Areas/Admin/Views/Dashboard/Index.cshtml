                <!--end::Small Box Widget 3-->
            </div>
            <!--end::Col-->
            <div class="col-lg-3 col-6">
                <!--begin::Small Box Widget 4-->
                <div class="small-box text-bg-danger">
                    <div class="inner">
                        <h3>@Model.TotalUsers</h3>
                        <p>Users</p>
                    </div>
                    <svg class="small-box-icon"
                         fill="currentColor"
                         viewBox="0 0 24 24"
