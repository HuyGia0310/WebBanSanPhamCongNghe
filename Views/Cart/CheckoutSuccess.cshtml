@model WebBanSanPhamCongNghe.Areas.Admin.Data.Payment

@functions {
    private string GetStatusClass(string? status) => status switch
    {
        "Đã đặt hàng" => "bg-warning text-dark",
        "Đang xử lý" => "bg-info text-dark",
        "Đang giao" => "bg-primary",
        "Hoàn thành" => "bg-success",
        "Đã hủy" => "bg-danger",
        _ => "bg-secondary"
    };
}

@{
    ViewData["Title"] = "Checkout Success";
    var statusClass = GetStatusClass(Model.Status);
}

<!-- Single Page Header start -->
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Đơn hàng</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
        <li class="breadcrumb-item active text-white">Xác nhận đơn hàng</li>
    </ol>
</div>
<!-- Single Page Header End -->

<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4 p-lg-5">
                        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
                            <div>
                                <p class="text-primary text-uppercase fw-semibold mb-1">Thanh toán thành công</p>
                                <h2 class="mb-1">Đơn hàng của bạn đã được ghi nhận</h2>
                                <p class="text-muted mb-0">Bạn có thể theo dõi trạng thái đơn hàng ngay bên dưới.</p>
                            </div>
                            <span class="badge rounded-pill fs-6 px-3 py-2 @statusClass">@Model.Status</span>
                        </div>

                        <div class="row g-4 mb-4">
                            <div class="col-md-4">
                                <div class="bg-light rounded p-3 h-100">
                                    <small class="text-uppercase text-muted d-block mb-1">Mã đơn hàng</small>
                                    <strong class="fs-5">#@Model.Id</strong>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="bg-light rounded p-3 h-100">
                                    <small class="text-uppercase text-muted d-block mb-1">Ngày mua</small>
                                    <strong class="fs-5">@((Model.CreateAt?.ToString("dd/MM/yyyy HH:mm")) ?? "N/A")</strong>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="bg-light rounded p-3 h-100">
                                    <small class="text-uppercase text-muted d-block mb-1">Tổng tiền</small>
                                    <strong class="fs-5">@($"{(Model.Total ?? 0):#,##0} VND")</strong>
                                </div>
                            </div>
                        </div>

                        <h4 class="mb-3">Chi tiết sản phẩm</h4>
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Sản phẩm</th>
                                        <th>Đơn giá</th>
                                        <th>Số lượng</th>
                                        <th class="text-end">Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.PaymentDetails)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-3">
                                                    <img src="~/Images/Product/@item.Product.Img"
                                                         alt="@item.Product.Title"
                                                         class="rounded border bg-white"
                                                         style="width: 72px; height: 72px; object-fit: cover;">
                                                    <div>
                                                        <div class="fw-semibold">@item.Product.Title</div>
                                                        <small class="text-muted">Mã SP: @item.ProductId</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>@($"{(item.Price ?? 0):#,##0} VND")</td>
                                            <td>@item.Quantity</td>
                                            <td class="text-end">@($"{(item.Total ?? 0):#,##0} VND")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex flex-column flex-sm-row gap-2 mt-4">
                            <a asp-controller="Product" asp-action="Index" class="btn btn-primary rounded-pill px-4 py-3">
                                Tiếp tục mua sắm
                            </a>
                            <a asp-controller="Customer" asp-action="OrderHistory" class="btn btn-outline-secondary rounded-pill px-4 py-3">
                                Xem lịch sử đơn hàng
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
