@using X.PagedList;
@using X.PagedList.Mvc.Core;
@model IPagedList<WebBanSanPhamCongNghe.Models.ProductViewModel>

@{
    ViewData["Title"] = "Product";
}

<!-- Single Page Header start -->
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Shop</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a href="#">Home</a></li>
        <li class="breadcrumb-item"><a href="#">Pages</a></li>
        <li class="breadcrumb-item active text-white">Shop</li>
    </ol>
</div>
<!-- Single Page Header End -->
<!-- Fruits Shop Start-->
<div class="container-fluid fruite py-5">
    <div class="container py-5">
        <h1 class="mb-2">My shop</h1>
        <p class="mb-4">Tìm Kiếm: @ViewData["Search"]</p>
        <div class="row g-4">
            <div class="col-lg-12">
                <div class="row g-4">
                    <div class="col-xl-3">
                        <form asp-controller="Product" asp-action="Index" asp-route-idCategory="@ViewData["IdCategory"]"
                               asp-route-sort="@ViewData["Sort"]" class="input-group w-100 mx-auto d-flex">
                            <input type="search"
                                   name="search"
                                   class="form-control p-3"
                                   placeholder="keywords"
                                   aria-describedby="search-icon-1" />
                            <button type="submit" id="search-icon-1" class="input-group-text p-3">
                                <i class="fa fa-search"></i>
                            </button>
                        </form>
                    </div>
                    <div class="col-6"></div>
                    <div class="col-xl-3">
                        <form asp-controller="Product" asp-action="Index" asp-route-idCategory="@ViewData["IdCategory"]"
                              asp-route-search="@ViewData["Search"]"  class="bg-light ps-3 py-3 rounded d-flex justify-content-between mb-4">
                            <label for="sort">Sắp Xếp Theo:</label>
                            <select id="sort"
                                    name="sort"
                                    class="border-0 form-select-sm bg-light pb-1 me-3"
                                    onchange="this.form.submit()"
                                    asp-items="@ViewBag.SortOptions">
                            </select>
                        </form>
                    </div>
                </div>
                <div class="row g-4">
                    <!-- Left Panel Start-->
                    <div class="col-lg-3">
                        <div class="row g-4">
                            <!-- Categories Start -->
                            <div class="col-lg-12">
                                <div class="mb-3">
                                    <h4>Categories</h4>
                                    @await Component.InvokeAsync("MenuCategory")
                                </div>
                            </div>
                            <!-- Categories End -->
                            <!-- Featured products Start -->
                            <div class="col-lg-12">
                                <h4 class="mb-3">Featured products</h4>
                                @await Component.InvokeAsync("FeaturedProducts", new { limit = 5 })
                            </div>
                            <!-- Featured products End -->
                        </div>
                    </div>
                    <!-- Left Panel End -->
                    <!-- Right Panel Start-->
                    <div class="col-lg-9">
                        <div class="row g-4 justify-content-center">
                            @foreach (var item in Model)
                            {
                                <!-- Item 1 Start -->
                                <div class="col-md-6 col-lg-6 col-xl-4">
                                    <div class="rounded position-relative fruite-item">
                                        <div class="fruite-img">
                                            <a asp-area="" asp-controller="Product" asp-action="Details" asp-route-id="@item.Id">
                                                <img src="~/Images/Product/@item.Img" class="img-fluid w-100 rounded-top" style="aspect-ratio:1.5; object-fit:cover" alt="@item.Img" />
                                            </a>
                                        </div>
                                        <div class="text-white bg-secondary px-3 py-1 rounded position-absolute" style="top: 10px; left: 10px">
                                            @item.CategoryTitle
                                        </div>
                                        <div class="p-4 border border-secondary border-top-0 rounded-bottom">
                                            <h5 style="line-height:1.5rem; height:3rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                                                @item.Title
                                            </h5>
                                            <p style="line-height:1.5rem; height:4.5rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                                @item.Content
                                            </p>
                                            <div class="d-flex justify-content-start flex-lg-wrap">
                                                <p class="text-dark fs-6 fw-bold mb-0">@item.Price?.ToString("#,##0 VND")</p>
                                            </div>
                                            <div class="d-flex justify-content-start flex-lg-wrap mt-3">
                                                <button onclick="clickAddToCart(@item.Id)" class="btn border border-secondary rounded-pill px-3 text-primary">
                                                    <i class="fa fa-shopping-bag me-2 text-primary"></i> Add to cart
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- Item 1 End -->
                            }

                            <!-- Pagination Start-->
                            <div class="col-12">
                                <div class="pagination d-flex justify-content-center mt-5">
                                    <a href="@Url.Action("Index", new {
                                        idCategory = ViewData["IdCategory"],
                                        search = ViewData["Search"],
                                        sort = ViewData["Sort"],
                                        page = Model.HasPreviousPage ? Model.PageNumber - 1 : 1
                                    })" class="rounded">&laquo;</a>
                                    @for (var i = 1; i <= Model.PageCount; i++)
                                    {
                                        <a href="@Url.Action("Index", new {
                                            idCategory = ViewData["IdCategory"],
                                            search = ViewData["Search"],
                                            sort = ViewData["Sort"],
                                            page = i
                                        })"
                                           class="rounded @(Model.PageNumber == i ? "active" : "")">@i</a>
                                    }
                                    <a href="@Url.Action("Index", new {
                                        idCategory = ViewData["IdCategory"],
                                        search = ViewData["Search"],
                                        sort = ViewData["Sort"],
                                        page = Model.HasNextPage ? Model.PageNumber + 1 : Model.PageCount
                                    })" class="rounded">&raquo;</a>
                                </div>
                            </div>
                            <!-- Pagination End-->
                        </div>
                    </div>
                    <!-- Right Panel End -->
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Fruits Shop End-->

<script>
    // --------------- AJAX thêm vào giỏ hàng -------------------
    function clickAddToCart(idProduct) {
        $.ajax({
            url: '@Url.Action("AddToCart", "Cart")',
            data: { id: idProduct },
            success: function (data) {
                //Load lại Cart ViewComponent
                $.ajax({
                    url: '@Url.Action("RefreshCartViewComponent", "Cart")',
                    success: function (data) {
                        console.log(data)
                        $("#cart_view_component").html(data);
                    },
                    error: function (xhr, ajaxOptions, thrownError) {
                        console.log(thrownError)
                        alert("Error updating Cart ViewComponent.");
                    }
                });

                // // Hiển thị thông báo thêm thành công
                $("#modalAddToCartSuccess").modal('show');
            },
            error: function (xhr, ajaxOptions, thrownError) {
                //some errror, some show err msg to user and log the error
                alert(xhr.responseText);
            }
        });
    } 
</script>
